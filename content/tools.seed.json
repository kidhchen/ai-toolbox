      ],
      "methods": [
        {
          "id": "video-starting-prompt",
          "name": "视频生成起手式",
          "sourceCredit": "侠在 & 毛毛",
          "summary": "用于快速声明画质、镜头运动、角色一致性和禁止字幕/背景音乐等基础要求。",
          "optimizedPrompt": "请生成电影级质感的高完成度动画画面，保持角色形象与参考图一致。镜头可以使用推拉、旋转、俯拍、仰拍等动态运动，构图要有叙事信息。不要生成字幕、水印或背景音乐；角色配音需自然收尾，动作要配合台词并保持生动。"
        },
        {
          "id": "script-segmentation",
          "name": "分镜拆分",
          "sourceCredit": "Ame",
          "summary": "把剧本拆成连续分段，每段约15秒，并输出剧情描述、故事板、声音风格、对白时间点和音效说明。",
          "optimizedPrompt": "请将我提供的剧本拆分为连续视频段落，每段控制在约15秒内。每段输出剧情概述、0到15秒故事板、角色声音风格、对白出现时间段、环境声和动作音效说明。请保留原剧本对白，不添加字幕、水印或背景音乐，角色和场景需与参考保持一致。"
        },
        {
          "id": "scene-four-views",
          "name": "场景四视图",
          "sourceCredit": "未标注",
          "summary": "为单个场景生成高角度俯瞰、低角度仰视、侧面和反面四宫格视图。",
          "optimizedPrompt": "请基于这个场景生成四宫格视图：高角度俯瞰、低角度仰视、侧面视角、反面视角。四个视图需要保持同一场景设定和空间关系，并在图中标注每个视角名称。"
        },
        {
          "id": "image2-storyboard",
          "name": "Image2 故事板",
          "sourceCredit": "Ame",
          "summary": "根据角色三视图、场景参考和剧本生成故事板，用于衔接即梦等视频生成工具。",
          "optimizedPrompt": "请根据角色三视图、场景参考和剧本内容生成故事板。故事板需包含角色展示、场景展示、必要的场景四视图，以及九宫格剧情画面。每格请补充情节要点、人物动作、台词、景别、镜头类型、运镜和镜头参数建议。"
        }
      ],
